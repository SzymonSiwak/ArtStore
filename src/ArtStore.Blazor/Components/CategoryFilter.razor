@using ArtStore.Shared.Enums
@using MudBlazor


<MudSelect T="Guid?"
           Label="Category"
           Value="SelectedCategory"
           ValueChanged="OnValueChanged"
           Clearable="true"
           Class="mb-4">
    <MudMenuItem Value="(Guid?)null">Loading categories...</MudMenuItem>
<!--

    @foreach (Category cat in Enum.GetValues(typeof(Category)))
    {
        <MudSelectItem Value="(Category?)cat">@cat</MudSelectItem>
    }
-->
</MudSelect>

@code {
    [Parameter]
    public Guid? SelectedCategory { get; set; }

    [Parameter]
    public EventCallback<Guid?> SelectedCategoryChanged { get; set; }

    private async Task OnValueChanged(Guid? newValue)
    {
        SelectedCategory = newValue;
        await SelectedCategoryChanged.InvokeAsync(newValue);
    }
}