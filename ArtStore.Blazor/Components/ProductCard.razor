@using ArtStore.Blazor.Interfaces
@using ArtStore.Blazor.Services
@using ArtStore.Shared.DTO
@inject IUserProfileService UserService
@inject ISnackbar Snackbar
@inject ICartService CartService
@inject NavigationManager NavigationManager
@implements IDisposable

<MudCard Elevation="0" Class="h-100 bg-transparent rounded-0" Style="cursor: pointer;" @onclick="GoToDetails">
	    <div style="width: 100%; aspect-ratio: 3/4; overflow: hidden; background-color: #f5f5f5;" class="mb-3">
		@if (!string.IsNullOrEmpty(ProductDto.ImageUrl))
        {
			<MudImage Src="@ProductDto.ImageUrl"
                      ObjectFit="ObjectFit.Cover" 
                      Style="width: 100%; height: 100%; transition: transform 0.3s ease;" 
                      Class="product-image-hover" />
        }
        else
        {
            <div class="d-flex justify-center align-center h-100">
                <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Size="Size.Large" Color="Color.Surface" />
            </div>
        }
    </div>

    <!-- CONTENT -->
    <MudCardContent Class="pa-0">
        
        <!-- TITLE AND LIKE ICON-->
        <div class="d-flex justify-space-between align-start w-100">
            <MudText Typo="Typo.subtitle1" Style="font-weight: 500; color: #1a1a1a; line-height: 1.2;" Class="mr-2">
				@ProductDto.Name
            </MudText>
            
            <!-- LIKE -->
			<MudIconButton Icon="@(UserService.IsFavorite(ProductDto.Id) ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
						   Color="@(UserService.IsFavorite(ProductDto.Id) ? Color.Error : Color.Default)"
                           Size="Size.Small"
                           Class="pa-0"
                           Style="color: #1a1a1a;"
                           OnClick="ToggleFav" 
                            />
        </div>

        <!-- ARTIST -->
        <MudText Typo="Typo.body2" Style="color: #666666; margin-top: 4px; margin-bottom: 8px;">
			@ProductDto.ArtistName
        </MudText>

        <!-- PRICE -->
        <MudText Typo="Typo.subtitle1" Style="font-weight: 700; color: #1a1a1a;">
            @ProductDto.Price @ProductDto.Currency
        </MudText>

    </MudCardContent>
</MudCard>

<style>
	.product-image-hover:hover {
		transform: scale(1.03); /* Lekkie przybliżenie po najechaniu */
	}
</style>

@code{
	[Parameter]
	public ProductDto ProductDto { get; set; } = new();
	private int quantity = 1;

	protected override void OnInitialized() => UserService.OnChange += RefreshUI;

	public void Dispose() => UserService.OnChange -= RefreshUI;

	private void RefreshUI()
	{
		// Forced UI refresh when favorites change
		InvokeAsync(StateHasChanged);
	}

	private async Task ToggleFav()
	{
		try
		{
			await UserService.ToggleFavorite(ProductDto.Id);

			if (UserService.IsFavorite(ProductDto.Id))
			{
				Snackbar.Add($"Added {ProductDto.Name} to favorites!", Severity.Success);
			}
			else
			{
				Snackbar.Add($"Removed {ProductDto.Name} from favorites!", Severity.Info);
			}
		}
		catch (Exception ex) when (ex.Message.Contains("401") || ex.Message.Contains("Unauthorized"))
		{
			Snackbar.Add("Firstly - sign in. Your piece of art will be waiting for You!", Severity.Warning);
			NavigationManager.NavigateTo("/login");
		}
	}

	private async Task AddToCart()
	{
		bool success = await CartService.TryAddToCartAsync(ProductDto.Id, 1);

		if (success)
		{
			Snackbar.Add($"Added {ProductDto.Name} to cart!", Severity.Success);
		}
		else
		{
			Snackbar.Add("Firstly - sign in. Your piece of art will be waiting for You!", Severity.Warning);
			NavigationManager.NavigateTo("/login");
		}
	}

	private void GoToDetails()
	{
		if (ProductDto.Id == Guid.Empty)
		{
			Console.WriteLine("BŁĄD: ID produktu jest puste (same zera)!");
			return;
		}

		NavigationManager.NavigateTo($"/product/{ProductDto.Id}");
	}
}