@page "/collections"
@page "/bestsellers"
@page "/new-arrivals"

@using ArtStore.Blazor.Components
@using ArtStore.Blazor.Interfaces
@using ArtStore.Blazor.Services
@using ArtStore.Shared.DTO
@using ArtStore.Shared.Enums
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject ICollectionService CollectionService
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>@FormatTitle(GetActiveRoute())</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pt-16 mt-8 mb-16">

    <MudBreadcrumbs Items="_breadcrumbs" Separator=">" Class="pa-0 mb-4" Style="font-size: 0.9rem; color: #666;">
        <ItemTemplate Context="item">
            <MudLink Href="@item.Href" Underline="Underline.Hover" Color="Color.Inherit">
                @item.Text.ToUpper()
            </MudLink>
        </ItemTemplate>
    </MudBreadcrumbs>

    <!-- Title -->
    <MudText Typo="Typo.h3" Style="font-weight: 500;" Class="mb-4">
        @FormatTitle(GetActiveRoute())
    </MudText>

    <!-- Description -->
    <MudText Typo="Typo.body1" Class="mb-8" Style="max-width: 900px; line-height: 1.6; color: #4a4a4a;">
        @GetDescription(GetActiveRoute())
    </MudText>

    <!-- Dark line -->
    <MudDivider Class="mb-8" style="border-color: #000;" />

    <div class="d-flex gap-4 mb-8 flex-wrap align-center">

        <!-- Category filter -->
        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                 Label="@GetCategoryLabel()"
                 Class="@(filter.CategoryId.HasValue ? "filter-button filter-button-active" : "filter-button")"
                 Variant="Variant.Text"
                 AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopLeft">

            <MudMenuItem OnClick="@(() => OnCategoryChanged(null))">All Categories</MudMenuItem>
            @if (categories != null)
            {
                @foreach (var cat in categories)
                {
                    <MudMenuItem OnClick="@(() => OnCategoryChanged(cat.Id))">@cat.Name</MudMenuItem>
                }
            }
        </MudMenu>


        <!-- Collection filter-->
        @if (string.IsNullOrEmpty(CollectionName))
        {
            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Label="@GetCollectionLabel()"
                     Class="@(filter.CollectionId.HasValue ? "filter-button filter-button-active" : "filter-button")"
                     Variant="Variant.Text"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft">

                <MudMenuItem OnClick="@(() => OnCollectionChanged(null))">All Collections</MudMenuItem>
                @if (allCollections != null)
                {
                    @foreach (var col in allCollections)
                    {
                        <MudMenuItem OnClick="@(() => OnCollectionChanged(col.Id))">@col.Name</MudMenuItem>
                    }
                }
            </MudMenu>
        }
        
        <!-- Frame filter -->
        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                 Label="@(filter.FrameType.HasValue ? filter.FrameType.ToString() : "Frame")"
                 Class="@(filter.FrameType.HasValue ? "filter-button filter-button-active" : "filter-button")"
                 Variant="Variant.Text"
                 AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopLeft">
            <MudMenuItem OnClick="@(() => OnFrameChanged(null))">Any Frame</MudMenuItem>
            @foreach (FrameType frame in Enum.GetValues(typeof(FrameType)))
            {
                <MudMenuItem OnClick="@(() => OnFrameChanged(frame))">@frame</MudMenuItem>
            }
        </MudMenu>

        <!-- Price filter -->
        <!-- ActivationEvent="MouseEvent.LeftClick", for unclosing menu -->
        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                 Label="Price"
                 Class="@(filter.MinPrice.HasValue || filter.MaxPrice.HasValue ? "filter-button filter-button-active" : "filter-button")"
                 Variant="Variant.Text"
                 AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopLeft"
                 Dense="true">
            <div class="pa-4" style="min-width: 300px;">

                <PriceFilter MinPrice="filter.MinPrice"
                             MaxPrice="filter.MaxPrice"
                             MinPriceChanged="OnMinPriceChanged"
                             MaxPriceChanged="OnMaxPriceChanged" />

                <!-- Clear -->
                <div class="d-flex justify-end mt-2">
                    <MudButton OnClick="ClearPrice" Size="Size.Small">Clear</MudButton>
                </div>
            </div>
        </MudMenu>

        <MudSpacer />

        <!-- Product's counting -->
        <MudText Typo="Typo.body2" Color="Color.Secondary">@products.Count() items</MudText>
    </div>

    <!-- Products -->
    @if (isLoading)
    {
        <div class="d-flex justify-center mt-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else
    {
        <ProductGrid Products="products" />
    }

</MudContainer>

@code {
    [Parameter]
    public string CollectionName { get; set; } = string.Empty;

    private IEnumerable<CollectionDto> allCollections = new List<CollectionDto>();
    private IEnumerable<CategoryDto> categories = new List<CategoryDto>();
    private IEnumerable<ProductDto> products = new List<ProductDto>();

    private ProductFilterDto filter = new();
    private bool isLoading = true;

    private List<BreadcrumbItem> _breadcrumbs = new List<BreadcrumbItem>();

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetAllCategoriesAsync();
        allCollections = await CollectionService.GetAllCollectionsAsync();

        NavigationManager.LocationChanged += HandleLocationChanged;

        await OnParametersSetAsync();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(async () =>
        {
            await OnParametersSetAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        var activeRoute = GetActiveRoute();
        var currentTitle = FormatTitle(activeRoute);

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem(currentTitle, href: null, disabled: true)
        };

        filter = new ProductFilterDto();

        if (activeRoute == "bestsellers" || activeRoute == "new-arrivals")
        {
            filter.CollectionSlug = activeRoute;
        }
        else if (!string.IsNullOrEmpty(CollectionName))
        {
            filter.CollectionSlug = CollectionName;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;

        //Refresh UI due to bug of not showing proper data after changing subpage
        StateHasChanged();
        var activeRoute = GetActiveRoute();
        products = await ProductService.GetFilteredProducts(filter); 
        isLoading = false;

        //Refresh UI due to bug of not showing proper data after changing subpage
        StateHasChanged();
    }

    private string GetActiveRoute()
    {
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower();

        if (uri.Contains("bestsellers")) return "bestsellers";
        if (uri.Contains("new-arrivals")) return "new-arrivals";
        if (!string.IsNullOrEmpty(CollectionName)) return CollectionName;

        return "artworks"; 
    }

    private string GetDescription(string routeName)
    {
        if (routeName == "artworks")
            return "Explore our complete gallery of unique art prints. Find the perfect piece for You.";
        if (routeName == "bestsellers")
            return "Discover our most popular art prints loved by customers worldwide.";
        if (routeName == "new-arrivals")
            return "Be the first to explore our latest additions and freshest designs.";

        return $"Explore our collection of {routeName.Replace("-", " ")} and find popular designs that reflect your taste and style.";
    }

    private string GetCategoryLabel()
    {
        if (!filter.CategoryId.HasValue)
            return "Category";
            
        var selectedCat = categories.FirstOrDefault(c => c.Id == filter.CategoryId.Value);
        return selectedCat != null ? selectedCat.Name : "Category";
    }

    private string GetCollectionLabel()
    {
        if (!filter.CollectionId.HasValue) return "Artworks";
        return allCollections.FirstOrDefault(c => c.Id == filter.CollectionId)?.Name ?? "Artworks";
    }

    private string FormatTitle(string name)
    {
        if (string.IsNullOrEmpty(name)) return "Artworks";
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(name.Replace("-", " "));
    }

    // --- Handlers ---

    private async Task OnCategoryChanged(Guid? newCategory)
    {
        filter.CategoryId = newCategory;
        await LoadData();
    }

    private async Task OnCollectionChanged(Guid? id)
    {
        filter.CollectionId = id;
        await LoadData();
    }

    private async Task OnFrameChanged(FrameType? newFrame)
    {
        filter.FrameType = newFrame;
        await LoadData();
    }

    private async Task OnMinPriceChanged(decimal? newMin)
    {
        filter.MinPrice = newMin;
        await LoadData();
    }

    private async Task OnMaxPriceChanged(decimal? newMax)
    {
        filter.MaxPrice = newMax;
        await LoadData();
    }

    private async Task ClearPrice()
    {
        filter.MinPrice = null;
        filter.MaxPrice = null;
        await LoadData();
    }
}