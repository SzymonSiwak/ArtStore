@page "/"
@using ArtStore.Blazor.Components
@using ArtStore.Blazor.Interfaces
@using ArtStore.Blazor.Services
@using ArtStore.Shared.DTO
@inject IProductService ProductService
@inject NavigationManager NavigationManager


<PageTitle>ArtStore - Home</PageTitle>

@if (homeData == null)
{
    <!-- Loader -->
    <div class="d-flex justify-center mt-5">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else
{
    <!-- Header -->
    <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-5 mt-5">Welcome to ArtStore</MudText>
    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-10">Discover unique art for your space.</MudText>

    <!--  NEW ARRIVALS -->
    <SectionHeader Title="New Arrivals" />
    <ProductGrid Products="homeData.NewArrivals" />

    <!-- COLLECTIONS -->
    <SectionHeader Title="Our Collections" />

    <MudGrid>
        @if (homeData?.FeaturedCollections != null)
        {
            @foreach (var col in homeData.FeaturedCollections)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Class="relative d-flex align-center justify-center rounded-lg overflow-hidden"
                              Style="height: 250px; cursor: pointer;"
                              @onclick="@(() => GoToCollection(col))">
                    
                        <!-- Baner kolekcji -->
                        <MudImage Src="@col.BannerImageUrl" ObjectFit="ObjectFit.Cover" Fluid="true" Style="width:100%; height:100%; position:absolute;" />
                    
                        <!-- Nakładka z nazwą -->
                        <div style="position:absolute; background: rgba(0,0,0,0.4); width:100%; height:100%;" class="d-flex align-center justify-center">
                            <MudText Typo="Typo.h4" Style="color: white; font-weight: bold; text-transform: uppercase;">@col.Name</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        }
    </MudGrid>
}

@code {
    private HomePageDto? homeData;

    protected override async Task OnInitializedAsync()
    {
        homeData = await ProductService.GetHomePageData();
    }

    private void GoToCollection(CollectionDto col)
    {
        NavigationManager.NavigateTo($"/collection/{col.Slug}");
    }

    RenderFragment<string> SectionHeader = title => __builder =>
    {
        <MudText Typo="Typo.h4" Class="mt-8 mb-4">@title</MudText>
        <MudDivider Class="mb-4" />
    };

    RenderFragment<IEnumerable<ProductDto>> ProductGrid = products => __builder =>
    {
        <MudGrid>
            @foreach (var product in products)
            {
                <MudItem xs="12" sm="6" md="3" lg="3" xl="2">
                    <ProductCard Product="product" />
                </MudItem>
            }
            @if (!products.Any())
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info">No products found in this category.</MudAlert>
                </MudItem>
            }
        </MudGrid>
    };
}