@using ArtStore.Blazor.Interfaces
@using ArtStore.Blazor.Services
@inherits LayoutComponentBase
@inject ISnackbar Snackbar
@inject IUserProfileService UserService
@inject NavigationManager NavigationManager
@inject ApiAuthenticationStateProvider ApiAuthenticationStateProvider

<MudThemeProvider Theme="Custom"/>
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar id="main-navbar"
               Fixed="true"
               Elevation="0"
               data-ishome="@IsHomePage.ToString().ToLower()"
               Class="@(IsHomePage ? "navbar-transparent px-4 px-md-16 pt-4 pt-4 pb-2" : "navbar-solid px-4 px-md-16 pt-4")">
               <div class="d-flex align-center justify-space-between w-100">
                    <MudButton Typo="Typo.h5" Class="ml-3 pa-0" OnClick="GoToHome" Style="@($"text-transform: none; color: {(IsHomePage ? "white" : "#1a1a1a")};")">
                        <MudText Typo="Typo.h4" Style="font-weight: 500; letter-spacing: 0.5px;">Square</MudText>
                    </MudButton>
                    <MudSpacer />

                    <div class="d-none d-md-flex gap-6 align-center h-100" >

                        @{
                            var linkColor = IsHomePage ? "white" : "#1a1a1a";
                        }
                        <MudButton Class=navBar Variant="Variant.Text" OnClick="GoToBestsellers" Style="@($"color: {linkColor}; text-transform: none; font-size: 1rem;")">Bestsellers</MudButton>
                        <MudButton Class=navBar Variant="Variant.Text" OnClick="GoToNewArrivals" Style="@($"color: {linkColor}; text-transform: none; font-size: 1rem;")">New Arrivals</MudButton>
                        <MudButton Variant="Variant.Text" OnClick="GoToCollections" Style="@($"color: {linkColor}; text-transform: none; font-size: 1rem;")">Artworks</MudButton>
                        <MudButton Class=navBar OnClick="GoToArtists" Style="@($"color: {linkColor}; text-transform: none; font-size: 1rem;")">Artists</MudButton>
                    </div>

                    <MudSpacer />

                    <div class="d-flex align-center gap-2 h-100" style="@($"color: {(IsHomePage ? "white" : "#1a1a1a")};")">
                        <!-- <MudIconButton Variant="Variant.Text" Icon="@Icons.Material.Outlined.Search"/> -->
                        <MudIconButton Variant="Variant.Text" OnClick="GoToCart" Color="Color.Inherit" Icon="@Icons.Material.Outlined.ShoppingCart"></MudIconButton>
                            <AuthorizeView Context="context">
                                <Authorized>
                                    <!-- Logged in -->
                                    <MudIconButton OnClick="GoToProfile" Color="Color.Inherit">
                                        <MudAvatar Style="@($"background-color: {(IsHomePage ? "white" : "#1a1a1a")}; color: {(IsHomePage ? "black" : "white")};")" Size="Size.Small">
                                            @(string.IsNullOrEmpty(context.User.Identity?.Name) ? "U" : context.User.Identity!.Name!.Substring(0, 1).ToUpper())
                                        </MudAvatar>
                                    </MudIconButton>
                                </Authorized>
                                <NotAuthorized>
                                    <!-- Not logged in -->
                                    <MudIconButton OnClick="GoToLogin" Color="Color.Inherit" Style= Icon="@Icons.Material.Outlined.Person"></MudIconButton>
                                </NotAuthorized>
                            </AuthorizeView>
                    </div>
               </div>
    </MudAppBar>

    <MudMainContent Class="pa-0"> 
        <MudContainer MaxWidth="MaxWidth.ExtraLarge">
            @Body
        </MudContainer>


        <footer style="background-color: #000000; color: #ffffff; padding-top: 80px; padding-bottom: 40px;">
            <MudContainer MaxWidth="MaxWidth.Large">
                
                <MudGrid Spacing="4">
                    <!-- column 1 -->
                    <MudItem xs="6" md="2">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: bold;">About</MudText>
                        <div class="d-flex flex-column gap-2">
                            <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">About us</MudLink>
                            <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Work</MudLink>
                            <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Press</MudLink>
                            <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Gifting</MudLink>
                        </div>
                    </MudItem>

                    <!-- column 2 -->
                    <MudItem xs="6" md="2">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: bold;">Help</MudText>
                        <div class="d-flex flex-column gap-2">
                            <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Contact us</MudLink>
                            <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Support</MudLink>
                            <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Delivery & Shipping</MudLink>
                            <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Returns</MudLink>
                        </div>
                    </MudItem>
                    
                    <MudItem xs="12" md="2"></MudItem> <!-- Blank space -->

                    <!-- column 3 -->
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h6" Class="mb-6" Style="font-weight: bold;">Sign up for newsletter</MudText>
                        
                        <!-- Custom input -->
                        <div class="d-flex align-center pb-2 mb-2" style="border-bottom: 1px solid white;">
                            <input type="email" placeholder="Enter the email" 
                                   style="background: transparent; border: none; color: white; width: 100%; outline: none;" />
                            <button style="background: transparent; border: none; color: white; cursor: pointer; text-transform: uppercase; font-size: 0.8rem;">
                                Subscribe
                            </button>
                        </div>
                        
                        <MudText Typo="Typo.caption" Style="color: #888;">
                            Sign up to our newsletter and get 10% off your first order
                        </MudText>

                        <!-- sc icons -->
                        <div class="mt-6 d-flex gap-4">
                            <MudIcon Icon="@Icons.Custom.Brands.Facebook" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Custom.Brands.Instagram" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Custom.Brands.Pinterest" Size="Size.Small" />
                        </div>
                    </MudItem>
                </MudGrid>

                <!-- buttom section -->
                <MudGrid Class="mt-16 align-center">
                    <MudItem xs="12" md="6">
                        <!-- Logo -->
                        <MudText Typo="Typo.h3" Style="font-weight: 500;">ArtStore</MudText>
                    </MudItem>
                    
                    <MudItem xs="12" md="6" Class="d-flex justify-end gap-8 flex-wrap">
                        <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link-small">Term of use</MudLink>
                        <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link-small">Privacy and policy</MudLink>
                        <MudLink Href="#" Color="Color.Inherit" Underline="Underline.None" Class="footer-link-small">Use of cookies</MudLink>
                    </MudItem>
                </MudGrid>
            </MudContainer>
        </footer>
    </MudMainContent>
</MudLayout>

<!-- Footer css -->
<style>
    .footer-link:hover {
        color: #aaaaaa !important; 
        text-decoration: underline;
    }

    .footer-link-small {
        font-size: 0.9rem;
        opacity: 0.8;
    }

    /* Input placeholder */
    ::placeholder {
        color: #666;
        opacity: 1;
    }
</style>

@code{
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool IsHomePage => NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim() == string.Empty ||
                               NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim() == "/";

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;

            if (authState.User.Identity?.IsAuthenticated == true)
            {
                try { await UserService.GetProfile(); } catch { }
            }
        }

        NavigationManager.LocationChanged += (sender, args) => StateHasChanged();
    }
    private void GoToLogin() => NavigationManager.NavigateTo("/login");
    private async Task GoToCart()
    {
        var authState = await ApiAuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
             NavigationManager.NavigateTo("/cart");
        }
        else
        {
            Snackbar.Add("Please login to view your cart.", Severity.Warning);
            NavigationManager.NavigateTo("/login");
	    }	
    }
    
    private void GoToHome() => NavigationManager.NavigateTo("/");
    private void GoToArtists() => NavigationManager.NavigateTo("/artists");
    private void GoToBestsellers() => NavigationManager.NavigateTo("/bestsellers");
    private void GoToNewArrivals() => NavigationManager.NavigateTo("/new-arrivals");
    private void GoToCollections() => NavigationManager.NavigateTo("/collections");
	private void GoToProfile() => NavigationManager.NavigateTo("/profile");

    MudTheme Custom = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Background = "#FFFEF6",
        }
    };
}