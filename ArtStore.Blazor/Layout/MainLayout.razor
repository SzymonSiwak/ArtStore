@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h5" Class="ml-3">ArtStore</MudText>
        <MudSpacer />

        <MudButton Link="/" Variant="Variant.Text" Color="Color.Inherit">Home</MudButton>
        <MudButton Link="/cart" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.ShoppingCart">Koszyk</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="GoToLogin">Logowanie</MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code{
    private void GoToLogin() => NavigationManager.NavigateTo("/login");
}