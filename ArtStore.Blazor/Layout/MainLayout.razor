@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<MudThemeProvider />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h5" Class="ml-3" OnClick="GoToHome">ArtStore</MudText>
        <MudSpacer />

        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="GoToHome">Home</MudButton>

        <MudButton OnClick="GoToBestsellers">Bestsellers</MudButton>
        <MudButton OnClick="GoToNewArrivals">New Arrivals</MudButton>
        <MudMenu Label="Shop by Room" Variant="Variant.Text">
            <MudMenuItem OnClick="GoToLiving">Living</MudMenuItem>
            <MudMenuItem OnClick="GoToStationary">Stationary</MudMenuItem>
        </MudMenu>

        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="GoToCart" StartIcon="@Icons.Material.Filled.ShoppingCart">Shopping Cart</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="GoToArtists">Artists</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="GoToLogin">Logowanie</MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code{
    private void GoToLogin() => NavigationManager.NavigateTo("/login");
	private void GoToCart() => NavigationManager.NavigateTo("/cart");
    private void GoToHome() => NavigationManager.NavigateTo("/");
	private void GoToArtists() => NavigationManager.NavigateTo("/artists");
	private void GoToBestsellers() => NavigationManager.NavigateTo("/collection/bestsellers");
	private void GoToNewArrivals() => NavigationManager.NavigateTo("/collection/new-arrivals");
	private void GoToLiving() => NavigationManager.NavigateTo("/collection/living");
	private void GoToStationary() => NavigationManager.NavigateTo("/collection/stationary");
}